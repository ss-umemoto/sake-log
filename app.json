{
  "expo": {
    "name": "日本酒ログ",
    "slug": "sake-log",
    "scheme": "sakelog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF8F2"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.umemoto.sakelog",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF8F2"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "カメラへのアクセスを許可すると、その場で撮影して記録に添付できます。"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f0eee91-94d6-486f-9013-5fd552de7270"
      }
    },
    "owner": "hijiri.umemoto"
  }
}
